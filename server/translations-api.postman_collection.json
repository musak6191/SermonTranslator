        {
          "name": "Update Translation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response contains updated translation', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('message').to.equal('Translation updated successfully');",
                  "    pm.expect(json.translation).to.have.property('updatedAt');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"originalText\":\"Masha'Allah\",\"translatedText\":\"What Allah has willed\",\"language\":\"en\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/translations/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "translations",
                "1"
              ]
            },
            "description": "Completely replace an existing translation. All required fields must be provided: originalText, translatedText, and language"
          },
          "response": [
            {
              "name": "Success - 200 OK",
              "originalRequest": {
