        {
          "name": "Create Translation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response contains created translation', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('message').to.equal('Translation created successfully');",
                  "    pm.expect(json.translation).to.have.property('id');",
                  "    pm.expect(json.translation).to.have.property('originalText');",
                  "    pm.expect(json.translation).to.have.property('translatedText');",
                  "    pm.expect(json.translation).to.have.property('language');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"originalText\":\"Subhanallah\",\"translatedText\":\"Glory be to God\",\"language\":\"en\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/translations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "translations"
              ]
            },
            "description": "Create a new translation with required fields: originalText, translatedText, and language"
          },
          "response": [
            {
              "name": "Success - 201 Created",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\"originalText\":\"Subhanallah\",\"translatedText\":\"Glory be to God\",\"language\":\"en\"}"
                },
                "url": {
                  "raw": "http://localhost:3001/api/translations",
                  "protocol": "http",
                  "host": [
                    "localhost"
                  ],
                  "port": "3001",
                  "path": [
                    "api",
                    "translations"
                  ]
                }
              },
              "status": "Created",
              "code": 201,
              "header": [],
              "body": "{\"message\":\"Translation created successfully\",\"translation\":{\"id\":3,\"originalText\":\"Subhanallah\",\"translatedText\":\"Glory be to God\",\"language\":\"en\",\"createdAt\":\"2026-04-05T12:11:37.344Z\"}}"
            },
            {
              "name": "Bad Request - 400 (Missing Field)",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\"originalText\":\"Alhamdulillah\"}"
                },
                "url": {
                  "raw": "http://localhost:3001/api/translations",
                  "protocol": "http",
                  "host": [
                    "localhost"
                  ],
                  "port": "3001",
                  "path": [
                    "api",
                    "translations"
                  ]
                }
              },
              "status": "Bad Request",
              "code": 400,
              "header": [],
              "body": "{\"error\":\"Missing required fields\",\"missingFields\":[\"translatedText\",\"language\"]}"
            }
          ]
