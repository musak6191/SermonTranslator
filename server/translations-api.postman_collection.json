                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "translations",
                "1"
              ]
            },
            "description": "Retrieve a specific translation by ID. Change the ID in the URL to the desired translation ID."
          },
          "response": [
            {
              "name": "Success - 200 OK",
              "originalRequest": {
                "method": "GET",
                "header": [],
