              "code": 200,
              "header": [],
              "body": "[{\"id\":1,\"originalText\":\"Assalamu alaikum\",\"translatedText\":\"Peace be upon you\",\"language\":\"en\",\"createdAt\":\"2026-04-01T00:00:00.000Z\"},{\"id\":2,\"originalText\":\"Bismillah\",\"translatedText\":\"In the name of God\",\"language\":\"en\",\"createdAt\":\"2026-04-02T00:00:00.000Z\"}]"
            }
