generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}
model User {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  createdAt DateTime @default(now())
  sessionsAsImam       Session[] @relation("SessionImam")
  participatedSessions Session[] @relation("SessionParticipants")
  @@map("users")
}
model Session {
  id          Int      @id @default(autoincrement())
  imamId      Int
  imam        User     @relation("SessionImam", fields: [imamId], references: [id])
  title       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  participants User[]  @relation("SessionParticipants")
  translations Translation[]
  @@map("sessions")
}
model Translation {
  id             Int      @id @default(autoincrement())
  sessionId      Int
  session        Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  originalText   String
  translatedText String
  language       String
  createdAt      DateTime @default(now())
  @@map("translations")
}
